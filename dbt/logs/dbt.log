  create table "$scratch"."silver_matches_physical"
   
  
  
  
  

  

  as (
    

with standardized_matches as (
    select
        match_date,
        home_team,
        away_team,
        result_ft,
        league_code,
        season_label,
        run_id,
        ingest_date,
        home_goals_ft,
        away_goals_ft,
        home_goals_ht,
        away_goals_ht,
        home_shots,
