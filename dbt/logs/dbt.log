        odds_b365_draw,
        odds_b365_away,
        odds_pinnacle_home,
        odds_pinnacle_draw,
        odds_pinnacle_away,
        odds_avg_home,
        odds_avg_draw,
        odds_avg_away,
        row_number() over (
            partition by
                season_label,
                league_code,
                match_date,
                home_team,
                away_team
            order by ingest_date desc, run_id desc
        ) as record_priority
    from "semantic"."stg_raw_matches_odds"
    where match_date is not null
      and home_team is not null
      and away_team is not null
)

select
    match_date,
    home_team,
    away_team,
    result_ft,
    league_code,
    season_label,
