  create or replace view "semantic"."stg_raw_matches_odds"
  
  as select
    to_date(nullif("Date", ''), 'DD/MM/YYYY') as match_date,
    cast(nullif("HomeTeam", '') as varchar) as home_team,
    cast(nullif("AwayTeam", '') as varchar) as away_team,
