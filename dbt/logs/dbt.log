    odds_b365_away,
    odds_pinnacle_home,
    odds_pinnacle_draw,
    odds_pinnacle_away,
    odds_avg_home,
    odds_avg_draw,
    odds_avg_away
from standardized_matches
where record_priority = 1
  )
  
