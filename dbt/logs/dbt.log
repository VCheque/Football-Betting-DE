  create or replace view "semantic"."gold_match_context"
  
  as with matches as (
    select *
    from "semantic"."stg_matches_odds"
),
home_form as (
    select
        league_code,
        match_date,
        home_team as team_name,
        avg(
            case result_ft
                when 'H' then 3
                when 'D' then 1
                else 0
            end
        ) over (
            partition by league_code, home_team
            order by match_date
            rows between 5 preceding and 1 preceding
        ) as home_last5_points_pg,
        avg(home_goals_ft) over (
            partition by league_code, home_team
            order by match_date
            rows between 5 preceding and 1 preceding
        ) as home_last5_goals_for_pg,
        avg(away_goals_ft) over (
            partition by league_code, home_team
            order by match_date
            rows between 5 preceding and 1 preceding
        ) as home_last5_goals_against_pg
    from matches
),
away_form as (
    select
        league_code,
        match_date,
        away_team as team_name,
        avg(
            case result_ft
                when 'A' then 3
                when 'D' then 1
                else 0
            end
        ) over (
            partition by league_code, away_team
            order by match_date
            rows between 5 preceding and 1 preceding
        ) as away_last5_points_pg,
        avg(away_goals_ft) over (
            partition by league_code, away_team
            order by match_date
            rows between 5 preceding and 1 preceding
        ) as away_last5_goals_for_pg,
        avg(home_goals_ft) over (
            partition by league_code, away_team
            order by match_date
            rows between 5 preceding and 1 preceding
        ) as away_last5_goals_against_pg
    from matches
)
select
    m.match_date,
    m.league_code,
    m.season_label,
    m.home_team,
    m.away_team,
    m.home_goals_ft,
    m.away_goals_ft,
    m.result_ft,
    m.odds_b365_home,
    m.odds_b365_draw,
    m.odds_b365_away,
    hf.home_last5_points_pg,
    hf.home_last5_goals_for_pg,
    hf.home_last5_goals_against_pg,
    af.away_last5_points_pg,
    af.away_last5_goals_for_pg,
    af.away_last5_goals_against_pg
from matches m
left join home_form hf
    on m.league_code = hf.league_code
   and m.match_date = hf.match_date
   and m.home_team = hf.team_name
left join away_form af
    on m.league_code = af.league_code
   and m.match_date = af.match_date
   and m.away_team = af.team_name
